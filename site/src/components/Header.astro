---
// Deployment targets: landing at /, demo SPA at /demo/, Storybook at /storybook/.
const nav = [
	{ label: 'Why', href: '/#why' },
	{ label: 'Stack', href: '/#stack' },
	{ label: 'Testing', href: '/#testing' },
	{ label: 'Workflow', href: '/#workflow' },
	{ label: 'Updates', href: '/updates' },
]
---

<header class="site-head">
	<div class="wrap head-inner">
		<a class="wordmark" href="/" aria-label="Karkas home">
			<span class="mark" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="22" height="22" fill="none">
					<rect x="2.5" y="2.5" width="19" height="19" stroke="currentColor" stroke-width="1.5"></rect>
					<path d="M2.5 2.5 21.5 21.5M21.5 2.5 2.5 21.5" stroke="currentColor" stroke-width="1"></path>
					<rect x="8" y="8" width="8" height="8" fill="var(--steel)"></rect>
				</svg>
			</span>
			<span class="wordtext">Karkas</span>
		</a>

		<nav class="site-nav" aria-label="Primary">
			{nav.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>

		<div class="head-cta">
			<a class="btn head-btn" href="/demo/">Open demo</a>
			<a class="ghlink" href="https://github.com/apphane-dev/karkas" aria-label="Karkas on GitHub">
				<svg viewBox="0 0 16 16" width="19" height="19" fill="currentColor" aria-hidden="true">
					<path
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
					></path>
				</svg>
			</a>
		</div>
	</div>
</header>

<style>
	.site-head {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in srgb, var(--paper) 86%, transparent);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--line-strong);
	}

	.head-inner {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		height: 62px;
	}

	.wordmark {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		text-decoration: none;
		color: var(--ink);
	}
	.mark {
		display: inline-flex;
		color: var(--blueprint);
	}
	.wordtext {
		font-family: var(--display);
		font-weight: 800;
		font-stretch: 125%;
		font-size: 1.28rem;
		letter-spacing: -0.01em;
	}

	.site-nav {
		display: flex;
		gap: 1.4rem;
		margin-left: auto;
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.03em;
	}
	.site-nav a {
		text-decoration: none;
		color: var(--ink-muted);
		padding-bottom: 2px;
		border-bottom: 1px solid transparent;
		transition:
			color 0.15s,
			border-color 0.15s;
	}
	.site-nav a:hover {
		color: var(--ink);
		border-color: var(--steel);
	}

	.head-cta {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}
	.head-btn {
		padding: 0.5rem 0.9rem;
		font-size: 0.76rem;
	}
	.ghlink {
		display: inline-flex;
		color: var(--ink);
		transition: color 0.15s;
	}
	.ghlink:hover {
		color: var(--steel);
	}

	@media (max-width: 820px) {
		.site-nav {
			display: none;
		}
	}
	@media (max-width: 520px) {
		.head-btn {
			display: none;
		}
	}
</style>
