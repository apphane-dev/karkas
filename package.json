		"preview": "mise run preview",
		"storybook": "mise run storybook",
		"test": "mise run test",
		"test:coverage": "mise run test:coverage",
		"test:run": "mise run test:run",
		"typecheck": "mise run typecheck",
		"validate": "mise run validate"
