		"@storybook/react-vite": "^10.4.6",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/browser-playwright": "4.1.9",
