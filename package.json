{
	"name": "modern-stack",
	"private": true,
	"type": "module",
	"module": "index.ts",
	"imports": {
		"#.storybook/*": "./.storybook/*",
		"#styled-system/*": "./src/shared/styled-system/*",
		"#theme/*": "./theme/*",
		"#*": "./src/*"
	},
	"scripts": {
		"build": "mise run build:webapp",
		"check": "mise run check",
		"dev": "mise run dev",
		"fix": "mise run fix",
		"format": "mise run format",
